# Helius mainnet RPC
HELIUS_RPC=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# House wallet SECRET key (base58 encoded)
# Generate with: solana-keygen new --outfile house-wallet.json
# Then convert: node -e "const k=require('./house-wallet.json');const bs58=require('bs58');console.log(bs58.encode(Buffer.from(k)))"
HOUSE_KEYPAIR=YOUR_BASE58_ENCODED_SECRET_KEY

# Frontend URL for CORS (set to your Railway frontend URL)
FRONTEND_URL=https://your-frontend.up.railway.app

# Port (Railway sets this automatically)
# PORT=3001
